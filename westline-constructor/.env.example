# Address of the Westline backend (server/).
# Local dev:  http://localhost:3001
# Production: https://api.yourdomain.com
#
# Copy to ".env" for `npm run dev` / `npm run app:dev`, or set it in the
# build environment for `npm run app:build` / `npm run app:publish`.
VITE_API_URL=http://localhost:3001
