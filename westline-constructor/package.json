{
  "name": "westline-constructor",
  "private": true,
  "version": "1.0.8",
  "type": "module",
  "description": "Конструктор сообщений для Discord-вебхуков в стиле Nothing OS.",
  "author": "Westline",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "app:dev": "concurrently -k -n VITE,ELECTRON -c magenta,cyan \"vite --port 5180 --strictPort --host 127.0.0.1\" \"wait-on http://127.0.0.1:5180 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5180 electron .\"",
    "app:build": "vite build && electron-builder --config.directories.output=C:/WestlineBuild",
    "app:build:dir": "vite build && electron-builder --dir --config.directories.output=C:/WestlineBuild",
    "app:publish": "vite build && electron-builder --publish always --config.directories.output=C:/WestlineBuild"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "javascript-obfuscator": "^5.4.3",
    "rollup-plugin-obfuscator": "^1.1.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.westline.constructor",
    "productName": "Westline Constructor",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yazvar",
        "repo": "webhook_constructor_westline",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Westline Constructor"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
