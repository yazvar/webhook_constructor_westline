# ============================================================
#  Westline backend configuration
#  Copy this file to ".env" and fill in the real values.
# ============================================================

# Port the API listens on.
PORT=3001

# Public URL of THIS backend, exactly as reachable from the outside.
# Used to build the Discord OAuth redirect URI.
# Local dev example: http://localhost:3001
# Production example: https://api.yourdomain.com
PUBLIC_URL=http://localhost:3001

# --- Discord application (https://discord.com/developers/applications) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Secret used to sign session JWTs. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated Discord user IDs that get access to the admin panel.
ADMIN_IDS=1202701219081224273,743400950646964264

# Where the SQLite database file is stored (relative to the server folder).
DB_PATH=./data/westline.db

# Comma-separated list of allowed CORS origins for the renderer.
# In the desktop app the renderer origin is "file://" (sent as null) and is
# always allowed; this is only relevant if you also serve the web build.
CORS_ORIGINS=http://localhost:5173,http://localhost:5180
